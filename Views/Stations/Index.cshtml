@model IEnumerable<GasStationApp.Models.Station>

@{
    ViewData["Title"] = "Gas Stations List";
}

<div class="container mt-4">
    <style>
        .brand-icon-sm {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2px;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
        }
        .brand-icon-sm img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: contain;
        }
        .status-ring-available { border: 2px solid #28a745 !important; }
        .status-ring-unavailable { border: 2px solid #dc3545 !important; }
    </style>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gas Stations</h1>
        <div>
            <button onclick="getLocation()" class="btn btn-outline-primary me-2">
                <i class="bi bi-geo-alt"></i> Find Nearest
            </button>
            <a asp-action="Map" class="btn btn-primary">View on Map</a>
        </div>
    </div>

    @if (ViewBag.UserLat != null)
    {
        <div class="alert alert-info py-2 d-flex justify-content-between align-items-center mb-4">
            <span>Sorting by distance from your current location.</span>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear Sort</a>
        </div>
    }

    <div class="row">
        @foreach (var station in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="brand-icon-sm me-3 @(station.LatestReport != null ? (station.LatestReport.available ? "status-ring-available" : "status-ring-unavailable") : "")">
                                <img src="@station.GetLogoPath()" 
                                     alt="@station.brand"
                                     onload="this.style.display='block'"
                                     onerror="this.style.display='none';this.parentElement.innerText='@(station.brand?.FirstOrDefault() ?? '?')'" />
                            </div>
                            <div>
                                <h5 class="card-title mb-0">@station.name</h5>
                                <h6 class="card-subtitle text-muted small">@station.brand</h6>
                            </div>
                        </div>
                        <p class="card-text small text-truncate mb-2"><i class="bi bi-geo-alt"></i> @station.street_address</p>
                        
                        <div class="mt-3">
                            <strong>Latest Status:</strong>
                            @if (station.LatestReport != null)
                            {
                                <div class="mt-2">
                                    <span class="badge @(station.LatestReport.available ? "bg-success" : "bg-danger")">
                                        @(station.LatestReport.available ? "Fuel Available" : "Out of Fuel")
                                    </span>
                                    <span class="badge bg-info text-dark">@station.LatestReport.fuel_type</span>
                                    <p class="mt-2 mb-0">
                                        <small>Queue: @station.LatestReport.queue_mins mins</small><br/>
                                        <small class="text-muted">Reported: @station.LatestReport.created_at.ToString("g")</small>
                                    </p>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No reports yet</p>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a asp-action="Details" asp-route-id="@station.id" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" 
                       asp-route-page="@(ViewBag.CurrentPage - 1)" 
                       asp-route-lat="@ViewBag.UserLat" 
                       asp-route-lng="@ViewBag.UserLng">Previous</a>
                </li>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-page="@i" 
                           asp-route-lat="@ViewBag.UserLat" 
                           asp-route-lng="@ViewBag.UserLng">@i</a>
                    </li>
                }
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" 
                       asp-route-page="@(ViewBag.CurrentPage + 1)" 
                       asp-route-lat="@ViewBag.UserLat" 
                       asp-route-lng="@ViewBag.UserLng">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        function getLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(showPosition, showError);
            } else {
                alert("Geolocation is not supported by this browser.");
            }
        }

        function showPosition(position) {
            const lat = position.coords.latitude;
            const lng = position.coords.longitude;
            window.location.href = `/Stations/Index?lat=${lat}&lng=${lng}`;
        }

        function showError(error) {
            switch(error.code) {
                case error.PERMISSION_DENIED:
                    alert("User denied the request for Geolocation.");
                    break;
                case error.POSITION_UNAVAILABLE:
                    alert("Location information is unavailable.");
                    break;
                case error.TIMEOUT:
                    alert("The request to get user location timed out.");
                    break;
                case error.UNKNOWN_ERROR:
                    alert("An unknown error occurred.");
                    break;
            }
        }
    </script>
}